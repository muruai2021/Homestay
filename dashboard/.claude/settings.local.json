{
  "permissions": {
    "allow": [
      "Bash(node server.js)",
      "Bash(curl -s -o /dev/null -w \"%{http_code}\" http://localhost:3000/dashboard-v2.html)",
      "Bash(npm run *)",
      "Bash(curl -s http://localhost:18800/json/version)",
      "Bash(start chrome *)",
      "Bash(tasklist //FI \"IMAGENAME eq chrome.exe\")",
      "Bash(node update-data.js)",
      "Bash(taskkill //F //IM chrome.exe)",
      "Bash(where chrome *)",
      "Bash(where \"C:/Program Files/Google/Chrome/Application/chrome.exe\")"
    ]
  }
}
